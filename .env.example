# Copy this file to .env and fill in real values. .env is gitignored.

# Used by the Streamlit "AI Assistant" page (frontend/app.py).
OPENAI_API_KEY=sk-your-key-here

# Comma-separated list of origins allowed to call the FastAPI backend (CORS).
# Add your deployed Streamlit URL here in production.
ALLOWED_ORIGINS=http://localhost:8501

# Base URL of the FastAPI backend, used by the Streamlit frontend.
# Point this at your deployed backend URL in production.
API_BASE_URL=http://127.0.0.1:8000
